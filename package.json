{
  "name": "claude-agent-accelerator-on-azure",
  "version": "1.0.0",
  "description": "Claude Agent SDK sample running on Azure with Microsoft Foundry",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "start:server": "node dist/server/index.js",
    "dev": "tsx watch src/index.ts",
    "dev:server": "tsx watch src/server/index.ts",
    "scenario": "tsx src/scenarios.ts",
    "scenario:1": "tsx src/scenarios.ts 1",
    "scenario:2": "tsx src/scenarios.ts 2",
    "scenario:3": "tsx src/scenarios.ts 3",
    "scenario:4": "tsx src/scenarios.ts 4",
    "lint": "eslint src --ext .ts",
    "test": "echo \"Tests to be added\" && exit 0"
  },
  "keywords": [
    "claude",
    "agent-sdk",
    "azure",
    "microsoft-foundry",
    "ai-agents"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.92",
    "@azure/monitor-opentelemetry": "^1.7.0",
    "@fastify/cors": "^11.2.0",
    "@fastify/static": "^9.0.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/resources": "^1.26.0",
    "@opentelemetry/sdk-trace-base": "^1.26.0",
    "@opentelemetry/sdk-trace-node": "^1.26.0",
    "@opentelemetry/semantic-conventions": "^1.27.0",
    "dotenv": "^16.4.5",
    "fastify": "^5.8.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@typescript-eslint/eslint-plugin": "^7.13.0",
    "@typescript-eslint/parser": "^7.13.0",
    "eslint": "^8.57.0",
    "tsx": "^4.15.0",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
