# Microsoft Foundry Configuration
# Get these values from your Azure AI Foundry project
FOUNDRY_API_KEY=your_foundry_api_key_here
FOUNDRY_BASE_URL=https://your-resource-name.services.ai.azure.com/anthropic/v1
FOUNDRY_MODEL=claude-sonnet-4-5
ANTHROPIC_VERSION=2023-06-01

# Alternative: Use Anthropic API directly for local development
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Application Configuration
PORT=3000
NODE_ENV=development

# Azure Application Insights (Optional for local dev)
APPLICATIONINSIGHTS_CONNECTION_STRING=
ENABLE_TRACING=false
ENABLE_EVALUATION=false

# Agent Configuration
MAX_ITERATIONS=10
ENABLE_SUBAGENTS=true
