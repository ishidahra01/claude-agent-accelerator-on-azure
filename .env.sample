# Microsoft Foundry Configuration
# API key is optional when using Microsoft Entra ID authentication.
CLAUDE_CODE_USE_FOUNDRY=1
ANTHROPIC_FOUNDRY_API_KEY=your_foundry_api_key_here
ANTHROPIC_FOUNDRY_RESOURCE=your-resource-name
# Or set the full base URL instead of ANTHROPIC_FOUNDRY_RESOURCE:
# ANTHROPIC_FOUNDRY_BASE_URL=https://your-resource-name.services.ai.azure.com/anthropic
ANTHROPIC_DEFAULT_OPUS_MODEL=claude-opus-4-6
ANTHROPIC_DEFAULT_SONNET_MODEL=claude-sonnet-4-6
ANTHROPIC_DEFAULT_HAIKU_MODEL=claude-haiku-4-5

# Alternative: Use Anthropic API directly for local development
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Application Configuration
PORT=3000
NODE_ENV=development

# Azure Application Insights (Optional for local dev)
APPLICATIONINSIGHTS_CONNECTION_STRING=
ENABLE_TRACING=false
ENABLE_EVALUATION=false

# Agent Configuration
MAX_ITERATIONS=10
ENABLE_SUBAGENTS=true
